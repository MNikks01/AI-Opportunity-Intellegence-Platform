{
  "name": "@aioi/ingestion-service",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "description": "Source workers: fetch, validate, dedupe, emit signal.ingested. Legality-gated.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aioi/ai-sdk": "workspace:*",
    "@aioi/database": "workspace:*",
    "@aioi/logger": "workspace:*",
    "@aioi/shared": "workspace:*",
    "@aioi/validation": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aioi/eslint-config": "workspace:*",
    "@aioi/tsconfig": "workspace:*"
  }
}
