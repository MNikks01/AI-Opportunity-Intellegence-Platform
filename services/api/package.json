{
  "name": "@aioi/api",
  "version": "0.8.17",
  "private": true,
  "type": "module",
  "description": "Fastify: tRPC (internal) + REST/OpenAPI (public) + WebSocket. Single business-logic layer.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aioi/ai-service": "workspace:*",
    "@aioi/auth": "workspace:*",
    "@aioi/billing": "workspace:*",
    "@aioi/cache": "workspace:*",
    "@aioi/database": "workspace:*",
    "@aioi/logger": "workspace:*",
    "@aioi/shared": "workspace:*",
    "@aioi/validation": "workspace:*",
    "@clerk/backend": "^1.15.0",
    "@trpc/server": "^11.0.0",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "stripe": "^17.0.0",
    "svix": "^1.24.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aioi/eslint-config": "workspace:*",
    "@aioi/tsconfig": "workspace:*"
  }
}
