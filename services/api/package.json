{
  "name": "@aioi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify: tRPC (internal) + REST/OpenAPI (public) + WebSocket. Single business-logic layer.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aioi/auth": "workspace:*",
    "@aioi/database": "workspace:*",
    "@aioi/logger": "workspace:*",
    "@aioi/shared": "workspace:*",
    "@aioi/validation": "workspace:*",
    "@trpc/server": "^11.0.0",
    "fastify": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aioi/eslint-config": "workspace:*",
    "@aioi/tsconfig": "workspace:*"
  }
}
