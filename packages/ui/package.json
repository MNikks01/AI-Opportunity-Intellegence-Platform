{
  "name": "@aioi/ui",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css"
  },
  "description": "Design-system components (tokens, primitives, composite) — see docs/03-design/DESIGN_SYSTEM.md.",
