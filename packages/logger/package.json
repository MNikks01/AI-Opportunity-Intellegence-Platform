{
  "name": "@aioi/logger",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "description": "Structured JSON logging (pino) with request/trace correlation.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@aioi/eslint-config": "workspace:*",
    "@aioi/tsconfig": "workspace:*"
  }
}
