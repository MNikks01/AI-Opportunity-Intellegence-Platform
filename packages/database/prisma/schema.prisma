// Canonical Prisma schema — AI Opportunity Intelligence Platform
// Design source of truth: docs/04-data/DATABASE_DESIGN.md (+ ERD.md).
// pgvector columns/HNSW indexes are added via a raw SQL migration (not expressible in PSL).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // Prisma 7 runs queries through a driver adapter (@prisma/adapter-pg, see src/client.ts), so no
  // native query-engine binary is shipped — this removes the old rhel-openssl-3.0.x serverless footgun.
}

datasource db {
  provider   = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (CLI/migrate) and the driver adapter (runtime),
  // not here. `extensions` stays — it's schema metadata Migrate uses to manage Postgres extensions.
  extensions = [pgvector(map: "vector"), pgcrypto]
}

// ───────────────────────── Tenancy & identity ─────────────────────────
model Organization {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String         @unique
  memberships   Membership[]
  workspaces    Workspace[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  briefs        Brief[]
  notifications Notification[]
  subscription  Subscription?
  integration   OrgIntegration?
  /// This org's own shareable referral code (generated on demand).
  referralCode   String?       @unique
  /// The referral code that brought this org in (set once, at referral time).
  referredByCode String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([referredByCode])
}

/// Per-org outbound integrations (B-034) — where the daily digest is delivered. Org-scoped config.
model OrgIntegration {
  organizationId    String       @id @db.Uuid
  slackWebhookUrl   String?
  discordWebhookUrl String?
  /// Telegram delivery (M8): a bot token + chat id the digest/alerts are sent to.
  telegramBotToken  String?
  telegramChatId    String?
  digestEnabled     Boolean      @default(true)
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// Newsletter subscribers (B-035) — the top-of-funnel list. Global (not org-scoped); unsubscribe is
/// token-based (a per-subscriber secret embedded in the email link).
model Subscriber {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  token          String    @unique
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
}

model User {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId     String       @unique
  email       String       @unique
  name        String?
  memberships Membership[]
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  BILLING
  VIEWER
}

model Membership {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @db.Uuid
  role           Role         @default(MEMBER)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

enum WorkspaceKind {
  PERSONAL
  TEAM
}

model Workspace {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @db.Uuid
  name           String
  kind           WorkspaceKind @default(PERSONAL)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  watchlists     Watchlist[]
  reports        Report[]
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?

  @@index([organizationId])
}

// ───────────────────────── Intelligence core (global) ─────────────────────────
enum LegalityTier {
  OFFICIAL
  LICENSED
  GRAY
  PROHIBITED
}

model Source {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String         @unique
  legalityTier LegalityTier
  tosUrl       String?
  rateConfig   Json
  enabled      Boolean        @default(true)
  /// AI/tech vertical (M1): default region for signals from this source; null = worldwide/unknown.
  region             Region?
  /// AI/tech vertical (M1): fallback Category.key applied when the classifier is low-confidence.
  defaultCategoryKey String?
  runs         IngestionRun[]
  signals      Signal[]
  createdAt    DateTime       @default(now())
}

enum IngestionStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model IngestionRun {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId   String          @db.Uuid
  status     IngestionStatus @default(RUNNING)
  cursor     String?
  itemCount  Int             @default(0)
  error      String?
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  source     Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
}

model Signal {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceId    String        @db.Uuid
  externalId  String
  url         String?
  title       String?
  raw         Json
  publishedAt DateTime?
  fetchedAt   DateTime      @default(now())
  source      Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  trends      TrendSignal[]
  analysis    SignalAnalysis?
  categories  SignalCategory[]

  @@unique([sourceId, externalId])
  @@index([publishedAt])
}

enum TrendStatus {
  EARLY
  ACTIVE
  FADING
  ARCHIVED
}

model Trend {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String        @unique
  title        String
  summary      String?
  status       TrendStatus   @default(EARLY)
  firstSeenAt  DateTime      @default(now())
  lastSignalAt DateTime?
  signals      TrendSignal[]
  entities     TrendEntity[]
  scores       Score[]
  snapshots    TrendSnapshot[]
  actionPlan   ActionPlan?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, lastSignalAt])
}

/// Append-only history point per trend, written once per pipeline run — the basis for momentum
/// (signal-count velocity) and opportunity trajectory over time.
model TrendSnapshot {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trendId     String   @db.Uuid
  signalCount Int
  opportunity Int?
  capturedAt  DateTime @default(now())
  trend       Trend    @relation(fields: [trendId], references: [id], onDelete: Cascade)

  @@index([trendId, capturedAt])
}

model TrendSignal {
  trendId  String @db.Uuid
  signalId String @db.Uuid
  weight   Float  @default(1)
  trend    Trend  @relation(fields: [trendId], references: [id], onDelete: Cascade)
  signal   Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@id([trendId, signalId])
  @@index([signalId])
}

enum EntityType {
  COMPANY
  MODEL
  REPO
  TOOL
  MCP_SERVER
  PAPER
  PERSON
}

model Entity {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         EntityType
  name         String
  externalRefs Json
  trends       TrendEntity[]
  snapshots    EntitySnapshot[]
  modelCard    ModelCard?
  createdAt    DateTime         @default(now())

  @@index([type, name])
}

/// Append-only history point per tracked supply-side entity (model / MCP server / repo), written once
/// per pipeline run — the raw material for entity momentum (the supply mirror of TrendSnapshot). Global.
model EntitySnapshot {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityId         String   @db.Uuid
  /// Number of trends linked to this entity at capture time.
  linkedTrendCount Int
  /// Total signal count across this entity's linked trends — the momentum metric.
  signalWeight     Int
  capturedAt       DateTime @default(now())
  entity           Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId, capturedAt])
}

model TrendEntity {
  trendId  String  @db.Uuid
  entityId String  @db.Uuid
  role     String?
  trend    Trend   @relation(fields: [trendId], references: [id], onDelete: Cascade)
  entity   Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([trendId, entityId])
  @@index([entityId])
}

enum ScoreDimension {
  OPPORTUNITY
  BUSINESS
  DEVELOPER
  CREATOR
  SEO
  COMPETITION
  MONETIZATION
  RISK
  DIFFICULTY
  PREDICTED_LIFETIME
}

enum ScoreBand {
  LOW
  MEDIUM
  HIGH
}

model Score {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trendId       String         @db.Uuid
  dimension     ScoreDimension
  value         Int            @db.SmallInt
  band          ScoreBand
  confidence    Float
  rationale     String
  evidence      Json
  rubricVersion String
  createdAt     DateTime       @default(now())
  trend         Trend          @relation(fields: [trendId], references: [id], onDelete: Cascade)

  @@unique([trendId, dimension, rubricVersion])
  @@index([dimension, value])
}

model ActionPlan {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trendId       String   @unique @db.Uuid
  promptVersion String
  content       Json // saasIdeas, apps, extensions, apis, content, keywords, domains, names, gtm, pricing, techStack, mvp, prd, architecture, ui, dbSchema, marketing, launch
  createdAt     DateTime @default(now())
  trend         Trend    @relation(fields: [trendId], references: [id], onDelete: Cascade)
}

// ───────────────── AI & Tech Intelligence vertical (M1, global) ─────────────────
// Taxonomy + per-article enrichment for the AI/tech news vertical. See
// docs/02-architecture/AI_TECH_INTELLIGENCE_MODULE.md and ADR-0009. All tables here are global
// intelligence data (no RLS), consistent with Source/Signal/Trend/Entity.

/// Coarse geography for filtering (country/region/worldwide). `country` granularity, when needed, is a
/// free-text field on SignalAnalysis; this enum is the primary filter axis.
enum Region {
  US
  CHINA
  INDIA
  EUROPE
  JAPAN
  SOUTH_KOREA
  SINGAPORE
  CANADA
  AUSTRALIA
  OTHER
}

/// Content taxonomy (AI Models, Coding AI, Video AI, …). Seeded from the canonical registry; supports a
/// single level of nesting via `parentId`.
model Category {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String           @unique
  name      String
  parentId  String?          @db.Uuid
  parent    Category?        @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[]       @relation("CategoryTree")
  signals   SignalCategory[]
  createdAt DateTime         @default(now())

  @@index([parentId])
}

/// Many-to-many Signal↔Category with the classifier's confidence, so low-confidence tags can be filtered
/// or re-reviewed.
model SignalCategory {
  signalId   String   @db.Uuid
  categoryId String   @db.Uuid
  confidence Float
  signal     Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([signalId, categoryId])
  @@index([categoryId])
}

/// 1:1 enrichment of a Signal — the per-article AI analysis (ADR-0009 decision 1). Kept separate from the
/// immutable raw Signal so re-analysis is a clean rewrite. `payload` carries the brief's 9 opportunity
/// axes (incl. Career/Learning/Automation/Startup/Freelancing) as narrative + sub-score objects. Written
/// by services/ai-service in M4; this migration only defines the table.
model SignalAnalysis {
  signalId         String   @id @db.Uuid
  region           Region
  /// BCP-47-ish language code of the source article (e.g. "en", "zh").
  language         String
  /// ≤50-word summary.
  tldr             String
  /// executiveSummary, whyItMatters, and per-axis { score, why } for business/developer/startup/
  /// investment/career/learning/content/automation/freelancing, plus skillsToLearn, companiesAffected,
  /// techMentioned, difficulty, industry, estMarketImpact, actionItems, confidence, trendingScore.
  payload          Json
  impactScore      Int      @db.SmallInt
  opportunityScore Int      @db.SmallInt
  credibilityScore Int      @db.SmallInt
  /// Cache key: identical content + prompt version ⇒ skip re-analysis (cost guardrail, ADR-0009).
  contentHash      String
  promptVersion    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  signal           Signal   @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([region, impactScore])
  @@index([opportunityScore])
  @@index([contentHash])
}

/// Supply-side detail for an Entity of type MODEL (open-source model tracking). Populated from Hugging
/// Face + registries in M9; this migration only defines the table.
model ModelCard {
  entityId      String   @id @db.Uuid
  license       String?
  paramsB       Float?
  /// Benchmark scores keyed by suite, e.g. { "mmlu": 0.82, "swe-bench": 0.41 }.
  benchmarks    Json?
  ggufAvailable Boolean  @default(false)
  ollamaTag     String?
  mlxAvailable  Boolean  @default(false)
  vllmSupported Boolean  @default(false)
  transformers  Boolean  @default(false)
  weightsUrl    String?
  updatedAt     DateTime @updatedAt
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// ───────────────────────── Tenant surfaces ─────────────────────────
model Watchlist {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @db.Uuid
  workspaceId    String          @db.Uuid
  name           String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items          WatchlistItem[]
  alerts         Alert[]
  createdAt      DateTime        @default(now())

  @@index([workspaceId])
}

enum WatchTargetType {
  TREND
  ENTITY
  TOPIC
}

model WatchlistItem {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  watchlistId String          @db.Uuid
  targetType  WatchTargetType
  targetId    String // Trend.id | Entity.id | topic slug
  watchlist   Watchlist       @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@unique([watchlistId, targetType, targetId])
}

enum AlertChannel {
  IN_APP
  EMAIL
  SLACK
  DISCORD
  TELEGRAM
  PUSH
}

enum AlertCadence {
  INSTANT
  DAILY_DIGEST
}

model Alert {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  watchlistId String       @db.Uuid
  trigger     Json // { type: NEW_TREND | SCORE_CROSSES | NEW_FUNDING, params }
  channel     AlertChannel @default(IN_APP)
  cadence     AlertCadence @default(INSTANT)
  enabled     Boolean      @default(true)
  watchlist   Watchlist    @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@index([watchlistId])
}

/// In-app notification produced when an Alert's trigger matches (B-017). Org-scoped (RLS).
model Notification {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @db.Uuid
  alertId        String?          @db.Uuid
  title          String
  body           String
  targetType     WatchTargetType?
  targetId       String?
  readAt         DateTime?
  /// Set once this notification has been delivered by email (for EMAIL-channel alerts).
  emailedAt      DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, readAt])
  @@index([organizationId, emailedAt])
}

model Brief {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  userId         String?      @db.Uuid
  kind           String // DAILY | WEEKLY
  content        Json
  deliveredAt    DateTime?
  openedAt       DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model Report {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @db.Uuid
  title       String
  content     Json
  exportUrl   String? // R2 object (PDF/deck)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model ApiKey {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  hashedKey      String       @unique
  scopes         String[]
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usage          ApiKeyUsage[]
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}

/// Per-key, per-day request counter for API rate limiting (B-036). `day` is a UTC YYYY-MM-DD string.
model ApiKeyUsage {
  apiKeyId String @db.Uuid
  day      String
  count    Int    @default(0)
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, day])
}

model Subscription {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String       @unique @db.Uuid
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String // FREE | PRO | TEAM | BUSINESS
  status               String
  entitlements         Json
  currentPeriodEnd     DateTime?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt            DateTime     @updatedAt
}

model AuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @db.Uuid
  actorUserId    String?      @db.Uuid
  action         String
  targetType     String?
  targetId       String?
  ip             String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  overrides   Json? // per-org overrides
  updatedAt   DateTime @updatedAt
}
