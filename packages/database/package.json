{
  "name": "@aioi/database",
  "version": "0.26.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "description": "Prisma client + schema + migrations (Postgres + pgvector).",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@aioi/ai-sdk": "workspace:*",
    "@aioi/auth": "workspace:*",
    "@aioi/billing": "workspace:*",
    "@aioi/intel-core": "workspace:*",
    "@aioi/logger": "workspace:*",
    "@aioi/shared": "workspace:*",
    "@aioi/validation": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@aioi/eslint-config": "workspace:*",
    "@aioi/tsconfig": "workspace:*",
    "@types/pg": "^8.11.10",
    "dotenv": "^17.4.2",
    "prisma": "^7.9.0"
  }
}
