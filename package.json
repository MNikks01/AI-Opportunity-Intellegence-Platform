{
  "name": "aioi-platform",
  "version": "0.0.0",
  "private": true,
  "description": "AI Opportunity Intelligence Platform — monorepo",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@aioi/eslint-config": "workspace:*",
    "@aioi/prettier-config": "workspace:*",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.12.0",
    "husky": "^9.1.0",
    "lint-staged": "^17.0.8",
    "msw": "^2.4.9",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
