# ── Core ─────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (Postgres + pgvector) ──────────────────────────────
DATABASE_URL=postgresql://aioi:aioi@localhost:5432/aioi?schema=public

# ── Redis (cache / BullMQ queues / Streams bus) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (S3-compatible: MinIO local / Cloudflare R2 prod) ─
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=aioi-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Auth (Clerk — behind packages/auth adapter) ─────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── AI gateway (LiteLLM) + providers ────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── LLM observability (Langfuse) ────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── App observability ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# ── Billing (Stripe) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Data source credentials (see data-source-integration skill) ─
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
PRODUCTHUNT_TOKEN=
YOUTUBE_API_KEY=
HUGGINGFACE_TOKEN=
