# ── Core ─────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (Postgres + pgvector) ──────────────────────────────
# Owner URL — used by Prisma migrations (schema changes).
DATABASE_URL=postgresql://aioi:aioi@localhost:5432/aioi?schema=public
# Restricted app role — the RUNTIME connects as this so RLS enforces (ADR-0003 / B-027). The role is
# created NOLOGIN by a migration; grant it login locally after `migrate dev`:
#   ALTER ROLE aioi_app WITH LOGIN PASSWORD 'aioi_app';
# In production, infra sets the login + password from secrets. Leave unset to fall back to DATABASE_URL
# (superuser — RLS will NOT enforce; dev only).
APP_DATABASE_URL=postgresql://aioi_app:aioi_app@localhost:5432/aioi?schema=public

# ── Redis (cache / BullMQ queues / Streams bus) ─────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (S3-compatible: MinIO local / Cloudflare R2 prod) ─
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=aioi-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Auth (Clerk — behind packages/auth adapter) ─────────────────
# With CLERK_SECRET_KEY set, the API verifies real session JWTs (else the dev StubAuthProvider).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY turns on the web app's Clerk sign-in (else the dev tenant).
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Signing secret for the Clerk webhook (POST /webhooks/clerk → bootstrapUser on user.created).
CLERK_WEBHOOK_SECRET=

# ── AI gateway (LiteLLM) + providers ────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# Signal→Trend clustering cosine threshold. Default 0.5 suits real embeddings (related posts ~0.55,
# unrelated ~0.2). Raise toward 1.0 for tighter clusters.
CLUSTER_THRESHOLD=0.5

# ── LLM observability (Langfuse) ────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── App observability ───────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# ── Billing (Stripe) ────────────────────────────────────────────
# With all three set, billing.checkout creates real Checkout sessions and /webhooks/stripe syncs plans
# (else a Stub URL + inert webhook). STRIPE_PRICE_PRO is the Price id for the Pro subscription.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# ── Email (Resend) ──────────────────────────────────────────────
# With both set, transactional email (daily briefs, alerts) sends via Resend; else a Stub outbox.
RESEND_API_KEY=
EMAIL_FROM=

# ── Data source credentials (see data-source-integration skill) ─
# GitHub: the connector works unauthenticated (60 req/h); a token raises the limit (5000 req/h).
# GITHUB_QUERY overrides the AI search (default "topic:llm"); a created:>= freshness filter is appended.
GITHUB_TOKEN=
GITHUB_QUERY=topic:llm
# Reddit: create a "script" app at reddit.com/prefs/apps. With id+secret set, the Reddit connector
# ingests hot posts from REDDIT_SUBREDDITS (app-only OAuth); unset → the connector no-ops.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="web:aioi:v1.0 (AI Opportunity Intelligence)"
REDDIT_SUBREDDITS=MachineLearning,LocalLLaMA,artificial,OpenAI,SaaS
# Product Hunt: developer token from api.producthunt.com/v2/oauth/applications. With it, the connector
# ingests top launches; unset → no-ops.
PRODUCTHUNT_TOKEN=
# YouTube: Data API v3 key. With it, the connector ingests AI videos (YOUTUBE_QUERY); unset → no-ops.
YOUTUBE_API_KEY=
YOUTUBE_QUERY="AI tools"
# Hugging Face: the connector works unauthenticated; a token raises the rate limit.
# HF_SORT tunes the models listing (likes | downloads | createdAt).
HUGGINGFACE_TOKEN=
HF_SORT=likes
